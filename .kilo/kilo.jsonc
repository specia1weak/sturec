{
  "$schema": "https://app.kilo.ai/config.json",
  "disabled_providers": [],
  "provider": {
    "packycode": {
      "name": "packy deepseek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://www.packyapi.com/v1"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash"
        },
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro"
        }
      }
    }
  },
  "permission": {
    "bash": "allow"
  },
  "model": "packycode/deepseek-v4-flash"
}